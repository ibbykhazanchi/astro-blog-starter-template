---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Welcome to My Blog</h1>
			<p>
				Hi, I'm Ibrahim Khajanchi. This is my personal blog where I share thoughts, tutorials, and
				experiences on topics I'm passionate about.
			</p>
			<p>
				Check out the <a href="/blog">blog posts</a> or learn more <a href="/about">about me</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
